{
  "name": "qywx-notifier-plus",
  "version": "2.0.0-dev",
  "description": "企业微信通知转发服务 - 类似Server酱的轻量级通知服务",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test --test-isolation=none test/backend-*.test.js test/frontend-*.test.js test/security.test.js test/review.test.js",
    "test:isolated": "node --test test/backend-*.test.js test/frontend-*.test.js test/security.test.js test/review.test.js",
    "test:live": "node --test test/live/*.test.js"
  },
  "keywords": [
    "wechat",
    "notification",
    "api",
    "webhook"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "form-data": "^4.0.6",
    "sqlite3": "^6.0.1",
    "wxcrypt": "^1.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "allowScripts": {
    "sqlite3": true
  }
}
