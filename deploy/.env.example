# =====================================================================
# 企业微信通知转发服务 - 环境变量配置（部署时填写）
#
# 使用方法：
#   1. 复制本文件为 .env :  cp .env.example .env
#   2. 执行 openssl rand -hex 32 两次，分别生成加密密钥和管理员密码
#   3. 修改下面所有【必改】标记的值
#   4. 执行 chmod 600 .env，并切勿把真实 .env 提交到 git
# =====================================================================

# ---------- 端口 ----------
# 同机 HTTPS 反代请设为 127.0.0.1；直接通过端口访问才使用 0.0.0.0。
HOST_BIND=0.0.0.0
# 宿主机端口（容器内固定 12121，无需修改）
HOST_PORT=12121

# ---------- 加密密钥【必改】----------
# 用于加密数据库中存储的 corpsecret / EncodingAESKey
# 必须是 32 位字符（字母数字均可）。可用下面命令生成一个随机值：
#   Linux/macOS: openssl rand -hex 32
#   Windows PowerShell: -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 32 | % {[char]$_})
ENCRYPTION_KEY=change-this-to-a-random-32-char-string

# ---------- 管理员登录【必改】----------
# ADMIN_USERNAME 可以保留 admin；建议按需修改
# ADMIN_PASSWORD 可使用 openssl rand -hex 32 生成，避免 $、# 等符号被误解析
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password

# ---------- 企业微信 API（通常无需修改）----------
WECHAT_API_BASE=https://qyapi.weixin.qq.com

# ---------- 反向代理（按部署方式选择）----------
# 应用端口仍能被公网直接访问时必须保持 false。
# 只有把端口绑定到 127.0.0.1/可信网段后，才可改为 loopback 或精确 CIDR。
TRUST_PROXY=false

# ---------- 隔离测试实例（生产环境留空）----------
# live 测试会在任何业务写入前精确比对此值；至少 16 个字符。
TEST_INSTANCE_ID=
