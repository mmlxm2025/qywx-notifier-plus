# =====================================================================
# 企业微信通知转发服务 - 环境变量配置（镜像拉取模式）
#
# 使用方法：
#   1. 复制本文件为 .env：  cp .env.example .env
#   2. 生成密钥：            openssl rand -hex 32  （执行两次，分别用于下方两个值）
#   3. 修改下面所有【必改】标记的值
#   4. 设置权限：            chmod 600 .env
#   5. 切勿把真实 .env 提交到 git
#
# 启动前会被校验的项（占位符未改则容器无法启动）：
#   ENCRYPTION_KEY、ADMIN_PASSWORD
# =====================================================================

# ---------- 服务端口（docker-compose 层面）----------
# 宿主机绑定 IP：0.0.0.0 = 对外开放；127.0.0.1 = 仅本机（配合同机反向代理）
HOST_BIND=0.0.0.0
# 宿主机端口（容器内固定 12121，无需修改）；被占用时可改为 8080 等
HOST_PORT=12121

# ---------- 加密密钥【必改】----------
# 用于加密数据库中存储的 corpsecret / EncodingAESKey / callback_token（AES-256）
# 解码后必须正好 32 字节，等价于下面任意一种：
#   - 64 位 hex        : openssl rand -hex 32
#   - 44 位 base64     : openssl rand -base64 32
#   - 32 个字符的字符串
# 切勿保留占位值，否则服务启动时拒绝监听端口。
ENCRYPTION_KEY=change-this-to-a-random-32-char-string

# ---------- 管理员登录【必改】----------
# ADMIN_USERNAME 可保留 admin，或按需修改
ADMIN_USERNAME=admin
# ADMIN_PASSWORD 至少 8 个字符；建议用 openssl rand -hex 32 生成，避免 $ # 等符号被 shell 误解析
ADMIN_PASSWORD=change-this-to-a-strong-password

# ---------- 企业微信 API（通常无需修改）----------
# 官方域名默认即可；指向非官方主机需同时在 compose 中开启 WECHAT_ALLOW_CUSTOM_API_BASE
WECHAT_API_BASE=https://qyapi.weixin.qq.com

# ---------- 反向代理（按部署方式选择）----------
# 应用端口仍能被公网直接访问时必须保持 false。
# 只有把端口绑定到 127.0.0.1/可信网段后，才可改为 loopback、跳数(1) 或精确 CIDR。
#   - 无反代 / 直接端口访问 : false
#   - 同机单层反代 (Nginx)  : loopback  或 1
#   - 多层代理               : 跳数(如 2) 或最外层可信 CIDR
TRUST_PROXY=false

# ---------- 隔离测试实例（生产环境留空）----------
# 仅隔离测试实例设置随机且唯一的 16+ 字符值；生产环境必须留空。
# 设置后会开放 /api/test-environment 探针，并用于 live 测试防误打生产。
TEST_INSTANCE_ID=

# =====================================================================
# 以下为调优项（均有代码默认值，无需修改；确有需要时取消注释调整）
# =====================================================================

# ---------- 请求体大小 ----------
# 回调接口 body 上限（字节）
# CALLBACK_MAX_BODY_BYTES=102400

# ---------- 限流 ----------
# 登录限流：5 分钟窗口内最大尝试次数（按 用户名+IP 递增退避）
# LOGIN_RATE_WINDOW_MS=300000
# LOGIN_RATE_MAX=10
# 通知发送接口限流：每分钟最大请求数
# NOTIFY_RATE_WINDOW_MS=60000
# NOTIFY_RATE_MAX=60
# 回调接口限流：每分钟最大请求数
# CALLBACK_RATE_WINDOW_MS=60000
# CALLBACK_RATE_MAX=120

# ---------- 优雅退出 ----------
# 优雅退出强制超时（毫秒，有效范围 [1000, 60000]）
# SHUTDOWN_TIMEOUT_MS=10000

# ---------- 通知鉴权（HMAC 防重放）----------
# NOTIFY_TIMESTAMP_TOLERANCE_SEC=300
# NOTIFY_NONCE_TTL_MS=600000
# NOTIFY_NONCE_HARD_LIMIT=10000

# ---------- 回调防重放（企业微信回调）----------
# CALLBACK_TIMESTAMP_TOLERANCE_SEC=300
# CALLBACK_NONCE_TTL_MS=600000
# CALLBACK_NONCE_HARD_LIMIT=50000

# ---------- 企微 API 调用 / 配额 / 缓存 ----------
# WECHAT_HTTP_TIMEOUT_MS=10000
# WECHAT_MAX_RESPONSE_BYTES=5242880
# WECHAT_MAX_REQUEST_BYTES=5242880
# CONFIG_CACHE_TTL_MS=60000
# MEMBER_CACHE_TTL_MS=300000
# SEND_DEDUP_TTL_MS=30000
# 单成员发送上限
# WECHAT_MEMBER_MINUTE_LIMIT=30
# WECHAT_MEMBER_HOUR_LIMIT=1000
# WECHAT_RATE_BACKOFF_MS=60000
